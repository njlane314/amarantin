#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
readonly ROOT_DIR=$(cd "${SCRIPT_DIR}/.." && pwd)
readonly -a MACRO_DIRS=("io/macro" "ana/macro" "plot/macro" "fit/macro")
cd "${ROOT_DIR}"

usage() {
  cat <<'EOF'
usage: tools/run-macro <macro-name> [args...]

Runs a ROOT macro by friendly name without exposing the raw ROOT command line.

Argument types are inferred from the macro signature.
Optional prefixes can override inference:
  s:<text>   explicit string
  i:<int>    integer
  f:<float>  floating-point
  b:true     boolean
  n:null     nullptr

Examples:
  tools/run-macro print_eventlist build/eventlists/run1.root
  tools/run-macro plot_topological_score build/eventlists/run1.root beam-s0
  tools/run-macro plot_event_display build/eventlists/run1.root beam-s0 0 U detector
  tools/run-macro plot_event_display build/eventlists/run1.root beam-s0 0 U detector 512 512
  tools/run-macro mk_snapshot build/eventlists/run1.root train.root reco_neutrino_vertex_x,__w__
  tools/run-macro fit_channel output.channels.root muon_region signal
  tools/run-macro scan_mu output.channels.root muon_region signal

Available names are discovered from:
  io/macro
  ana/macro
  plot/macro
  fit/macro
EOF
}

if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

macro_name=${1//-/_}
shift

macro_path=
for macro_dir in "${MACRO_DIRS[@]}"; do
  candidate="${macro_dir}/${macro_name}.C"
  if [[ -f "${candidate}" ]]; then
    macro_path=${candidate}
    break
  fi
done

if [[ -z "${macro_path}" ]]; then
  {
    echo "tools/run-macro: unknown macro: ${macro_name}"
    echo
    usage
  } >&2
  exit 1
fi

escape_cpp_string() {
  local s=$1
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  s=${s//$'\n'/\\n}
  s=${s//$'\t'/\\t}
  printf '%s' "${s}"
}

extract_signature() {
  local name=$1
  local path=$2
  awk -v name="${name}" '
    BEGIN { capture = 0 }
    {
      line = $0
      sub(/\/\/.*/, "", line)
      if (!capture && line ~ "^[[:space:]]*void[[:space:]]+" name "\\(")
        capture = 1
      if (capture)
      {
        printf "%s ", line
        if (line ~ /\)[[:space:]]*\{/ || line ~ /\)[[:space:]]*$/)
          exit
      }
    }
  ' "${path}"
}

literal_matches_kind() {
  local kind=$1
  local value=$2

  case "${kind}" in
    bool)
      [[ "${value}" == true || "${value}" == false ]]
      ;;
    int)
      [[ "${value}" =~ ^[-+]?[0-9]+$ ]]
      ;;
    float)
      [[ "${value}" =~ ^[-+]?[0-9]*\.?[0-9]+([eE][-+]?[0-9]+)?$ ]]
      ;;
    *)
      return 1
      ;;
  esac
}

parameter_kinds() {
  local signature=$1
  local params=${signature#*(}
  params=${params%)*}
  params=${params%\{}

  IFS=',' read -r -a raw_params <<< "${params}"
  local raw
  for raw in "${raw_params[@]}"; do
    raw=${raw%%=*}
    raw=$(printf '%s' "${raw}" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')
    [[ -z "${raw}" ]] && continue
    if [[ "${raw}" =~ (^|[[:space:]\*&])(bool)([[:space:]\*&]|$) ]]; then
      printf 'bool\n'
    elif [[ "${raw}" =~ Long64_t|int|size_t|unsigned[[:space:]]+long|unsigned[[:space:]]+int ]]; then
      printf 'int\n'
    elif [[ "${raw}" =~ float|double ]]; then
      printf 'float\n'
    else
      printf 'string\n'
    fi
  done
}

prefixed_literal() {
  local arg=$1
  local kind=
  local value=

  case "${arg}" in
    n:null)
      printf 'nullptr'
      return 0
      ;;
    b:*)
      kind=bool
      value=${arg#b:}
      ;;
    i:*)
      kind=int
      value=${arg#i:}
      ;;
    f:*)
      kind=float
      value=${arg#f:}
      ;;
    *)
      return 1
      ;;
  esac

  literal_matches_kind "${kind}" "${value}" || return 1
  printf '%s' "${value}"
}

to_cpp_literal() {
  local arg=$1
  local kind=${2:-string}

  if prefixed_literal "${arg}"; then
    return 0
  fi

  if literal_matches_kind "${kind}" "${arg}"; then
    printf '%s' "${arg}"
    return 0
  fi

  if [[ "${arg}" == s:* ]]; then
    arg=${arg#s:}
  fi

  printf '"%s"' "$(escape_cpp_string "${arg}")"
}

build_invocation() {
  local path=$1
  local name=$2
  shift 2

  if [[ $# -eq 0 ]]; then
    printf '%s' "${path}"
    return 0
  fi

  local signature
  signature=$(extract_signature "${name}" "${path}")
  local -a kinds=()
  local kind
  while IFS= read -r kind; do
    [[ -n "${kind}" ]] && kinds+=("${kind}")
  done < <(parameter_kinds "${signature}")

  local -a raw_args=("$@")
  local -a args=()
  local i
  for i in "${!raw_args[@]}"; do
    kind=string
    if [[ ${i} -lt ${#kinds[@]} ]]; then
      kind=${kinds[$i]}
    fi
    args+=("$(to_cpp_literal "${raw_args[$i]}" "${kind}")")
  done

  local joined=
  printf -v joined '%s, ' "${args[@]}"
  joined=${joined%, }

  printf '%s(%s)' "${path}" "${joined}"
}

invocation=$(build_invocation "${macro_path}" "${macro_name}" "$@")
exec root -l -q "${invocation}"
