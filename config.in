#!/bin/sh

prefix="@prefix@"
exec_prefix="@exec_prefix@"
includedir="@includedir@"
libdir="@libdir@"
version="@PACKAGE_VERSION@"

case "$1" in
  --prefix)
    echo "$prefix"
    ;;
  --version)
    echo "$version"
    ;;
  --cflags)
    echo "-I${includedir}"
    ;;
  --libs)
    echo "-L${libdir} -l@PROJECT_NAME@"
    ;;
  *)
    echo "usage: $0 [--prefix|--version|--cflags|--libs]" >&2
    exit 1
    ;;
esac
