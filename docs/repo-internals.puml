@startuml
' =============================================================================
' amarantin internals
' Workflow + persistent surfaces
' Intended to read like the EventSelectionFilter example: portrait, staged,
' and biased toward a narrow top-to-bottom flow.
' =============================================================================
!pragma layout smetana

top to bottom direction
' A4 portrait @160dpi ~ 1320x1870px: bias toward a taller-than-wide layout.
scale max 980*1750

skinparam defaultFontSize 10
skinparam wrapWidth 160
skinparam nodesep 8
skinparam ranksep 20
skinparam padding 1

!$INK     = "#111827"
!$MUTED   = "#6B7280"
!$ART     = "#1D4ED8"
!$TOOLS   = "#15803D"
!$CFG     = "#B45309"
!$DATA    = "#111827"
!$NOTE_BG = "#F9FAFB"
!$NOTE_BR = "#9CA3AF"

hide stereotype
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Helvetica
skinparam defaultFontColor $INK
skinparam linetype ortho
skinparam shadowing false
skinparam roundCorner 0
skinparam dpi 160
skinparam defaultTextAlignment center
skinparam LineThickness 1
skinparam ArrowThickness 1.1
skinparam ArrowColor $INK
skinparam packageStyle rectangle
skinparam componentStyle rectangle

skinparam component<<cfg>> {
  BackgroundColor #FEF3C7
  BorderColor $CFG
  FontColor $INK
}
skinparam artifact<<cfg>> {
  BackgroundColor #FEF3C7
  BorderColor $CFG
  FontColor $INK
}

skinparam package<<art>> {
  BackgroundColor #E3EAFD
  BorderColor $ART
  FontColor $INK
}
skinparam component<<art>> {
  BackgroundColor #E3EAFD
  BorderColor $ART
  FontColor $INK
}

skinparam package<<tools>> {
  BackgroundColor #E0F2E9
  BorderColor $TOOLS
  FontColor $INK
}
skinparam component<<tools>> {
  BackgroundColor #E0F2E9
  BorderColor $TOOLS
  FontColor $INK
}

skinparam artifact<<data>> {
  BackgroundColor #F3F4F6
  BorderColor $DATA
  FontColor $INK
}

skinparam note {
  BackgroundColor $NOTE_BG
  BorderColor $NOTE_BR
  FontColor $INK
}

' =============================================================================
' Configuration (minimal)
' =============================================================================
component "Shell / make / scripts\ninvoke mk_* binaries" as USER <<cfg>>
artifact "Workflow inputs\nsample list\nsample defs\nselection preset /\nselection expr\noptional cache spec" as CFG <<cfg>>

' =============================================================================
' Workflow stages
' =============================================================================
package "Workflow stages" <<art>> {
  component "mk_sample\n(app)" as MK_SAMPLE <<art>>
  component "mk_dataset\n(app)" as MK_DATASET <<art>>
  component "mk_eventlist\n(app)" as MK_EVENTLIST <<art>>
  component "ana::build_event_list(...)" as BUILD_EVENTLIST <<tools>>
  component "syst::build_systematics_cache(...)" as BUILD_SYST <<tools>>

  MK_SAMPLE -down-> MK_DATASET : workflow
  MK_DATASET -down-> MK_EVENTLIST : workflow

  MK_EVENTLIST -[hidden]down-> BUILD_EVENTLIST
  BUILD_EVENTLIST -[hidden]down-> BUILD_SYST
}

' =============================================================================
' Persistent products
' =============================================================================
package "Persistent products" {
  artifact "InputPartitionIO\nfile list + subrun scan" as INPUT <<data>>
  artifact "SampleIO\nsample ROOT container" as SAMPLE <<data>>
  artifact "DatasetIO\nkeyed samples\n+ provenance" as DATASET <<data>>
  artifact "EventListIO\nselected trees\n+ subrun trees\n+ selection metadata" as EVENTLIST <<data>>
  artifact "DistributionIO\nbin-wise caches\n+ systematics payloads" as DIST <<data>>
  artifact "ChannelIO\nprocess / channel view" as CHANNEL <<data>>

  INPUT -down-> SAMPLE
  SAMPLE -down-> DATASET
  DATASET -down-> EVENTLIST
  EVENTLIST -down-> DIST
  DIST -down-> CHANNEL
}

' =============================================================================
' Downstream consumers
' =============================================================================
package "Downstream consumers" <<art>> {
  component "snapshot::sample(...)\nsnapshot::merged(...)" as SNAPSHOT <<tools>>
  component "syst::evaluate(...)" as EVAL_SYST <<tools>>
  component "plot_utils::make_histogram(...)" as PLOT_HIST <<tools>>
  component "plot_utils::draw_event_display(...)" as PLOT_DISPLAY <<tools>>

  SNAPSHOT -[hidden]down-> EVAL_SYST
  EVAL_SYST -[hidden]down-> PLOT_HIST
  PLOT_HIST -[hidden]down-> PLOT_DISPLAY
}

' =============================================================================
' Layout nudges: three clean portrait columns
' =============================================================================
USER -down-> CFG : selects\nworkflow
CFG -[hidden]down-> MK_SAMPLE
MK_SAMPLE -[hidden]right-> INPUT
MK_DATASET -[hidden]right-> DATASET
BUILD_EVENTLIST -[hidden]right-> EVENTLIST
BUILD_SYST -[hidden]right-> DIST
EVENTLIST -[hidden]right-> SNAPSHOT
DIST -[hidden]right-> EVAL_SYST
CHANNEL -[hidden]right-> PLOT_HIST
EVENTLIST -[hidden]right-> PLOT_DISPLAY

' =============================================================================
' Wiring: configuration
' =============================================================================
CFG ..> MK_SAMPLE : input list +\nmetadata args
CFG ..> MK_DATASET : optional defs
CFG ..> MK_EVENTLIST : selection +\ncache args

' =============================================================================
' Wiring: production + consumption
' =============================================================================
MK_SAMPLE --> INPUT : scans files
MK_SAMPLE --> SAMPLE : writes

SAMPLE --> MK_DATASET : reads
MK_DATASET --> DATASET : writes

MK_EVENTLIST ..> BUILD_EVENTLIST : runs
DATASET --> BUILD_EVENTLIST : reads
BUILD_EVENTLIST --> EVENTLIST : writes\nselected rows

MK_EVENTLIST ..> BUILD_SYST : optional\ncache pass
EVENTLIST --> BUILD_SYST : source rows
BUILD_SYST --> DIST : writes bins\n+ syst cache
DIST --> CHANNEL : assemble\nprocess view

EVENTLIST --> SNAPSHOT : snapshot export
EVENTLIST ..> EVAL_SYST : direct row-wise path
DIST --> EVAL_SYST : persisted cache
EVENTLIST --> PLOT_HIST : exploratory plots
DIST --> PLOT_HIST : repeated plots
EVENTLIST --> PLOT_DISPLAY : event view

note bottom of INPUT
  InputPartitionIO is the per-partition scan state
  used during sample building before SampleIO is written.
end note

note bottom of BUILD_EVENTLIST
  ana is the DatasetIO -> EventListIO translation layer.
  mk_eventlist can then optionally drive systematic cache
  construction into DistributionIO.
end note

note bottom of PLOT_HIST
  plot reads EventListIO directly for row-wise views and
  DistributionIO for cached bin-wise rendering.

  ChannelIO remains the downstream process/channel surface
  in the preferred EventListIO -> DistributionIO -> ChannelIO ladder.
end note

@enduml
