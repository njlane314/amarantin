@startuml
' =============================================================================
' amarantin internals
' Data-flow view aligned to the current repo layout and DESIGN.md.
' =============================================================================
!pragma layout smetana

top to bottom direction
' A4 landscape @160dpi ~ 1870x1320px: keep the layout page-shaped, not panoramic.
scale max 1750*980

skinparam defaultFontSize 10
skinparam wrapWidth 160
skinparam nodesep 8
skinparam ranksep 20
skinparam padding 1

!$INK     = "#111827"
!$MUTED   = "#6B7280"
!$ART     = "#1D4ED8"
!$TOOLS   = "#15803D"
!$CFG     = "#B45309"
!$DATA    = "#111827"
!$NOTE_BG = "#F9FAFB"
!$NOTE_BR = "#9CA3AF"

hide stereotype
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Helvetica
skinparam defaultFontColor $INK
skinparam linetype ortho
skinparam shadowing false
skinparam roundCorner 0
skinparam dpi 160
skinparam defaultTextAlignment center
skinparam LineThickness 1
skinparam ArrowThickness 1.1
skinparam ArrowColor $INK
skinparam packageStyle rectangle
skinparam componentStyle rectangle

skinparam component<<cfg>> {
  BackgroundColor #FEF3C7
  BorderColor $CFG
  FontColor $INK
}
skinparam artifact<<cfg>> {
  BackgroundColor #FEF3C7
  BorderColor $CFG
  FontColor $INK
}

skinparam package<<art>> {
  BackgroundColor #E3EAFD
  BorderColor $ART
  FontColor $INK
}
skinparam component<<tools>> {
  BackgroundColor #E0F2E9
  BorderColor $TOOLS
  FontColor $INK
}

skinparam artifact<<data>> {
  BackgroundColor #F3F4F6
  BorderColor $DATA
  FontColor $INK
}

skinparam note {
  BackgroundColor $NOTE_BG
  BorderColor $NOTE_BR
  FontColor $INK
}

' =============================================================================
' Entry points + config
' =============================================================================
component "mk_sample" as MK_SAMPLE <<cfg>>
component "mk_dataset" as MK_DATASET <<cfg>>
component "mk_eventlist" as MK_EVENTLIST <<cfg>>
artifact "sample defs" as SAMPLE_DEFS <<cfg>>
artifact "selection preset /\nselection expr" as SELECT_CFG <<cfg>>

' =============================================================================
' Source-side persistence
' =============================================================================
package "Source persistence (io/)" <<art>> {
  artifact "InputPartitionIO\nfile list + subrun scan" as INPUT <<data>>
  artifact "SampleIO\nsample container" as SAMPLE <<data>>
  artifact "DatasetIO\nsample metadata\n+ provenance" as DATASET <<data>>

  INPUT -[hidden]down-> SAMPLE
  SAMPLE -[hidden]down-> DATASET
}

' =============================================================================
' Core modules + persisted event-list state
' =============================================================================
package "ana/" <<art>> {
  component "ana::build_event_list(...)\nselection + derived columns" as BUILD_EVENTLIST <<tools>>
}

package "Event-list persistence (io/)" <<art>> {
  artifact "EventListIO\nselected trees + subruns\nselection metadata" as EVENTLIST <<data>>
  artifact "systematics cache\n(stored inside EventListIO)\nnominal + detector/genie/flux/reint\ncovariance + eigenmodes" as SYSCACHE <<data>>

  EVENTLIST -[hidden]down-> SYSCACHE
}

package "syst/" <<art>> {
  component "syst::build_systematics_cache(...)\ncache requests -> evaluate()" as BUILD_SYST <<tools>>
  component "SystematicsEngine::evaluate(...)\nrow-wise or cache-backed" as EVAL_SYST <<tools>>

  BUILD_SYST -[hidden]down-> EVAL_SYST
}

package "io/ export" <<art>> {
  component "SnapshotService::snapshot_sample(...)\nSnapshotService::snapshot_merged(...)" as SNAPSHOT <<tools>>
}

package "plot/" <<art>> {
  component "plot_utils::make_histogram(...)\nselected-tree plots" as PLOT_HIST <<tools>>
  component "plot_utils::draw_event_display(...)\nevent view" as PLOT_DISPLAY <<tools>>

  PLOT_HIST -[hidden]down-> PLOT_DISPLAY
}

' =============================================================================
' Layout nudges
' =============================================================================
MK_SAMPLE -[hidden]right-> MK_DATASET
MK_DATASET -[hidden]right-> MK_EVENTLIST
SAMPLE_DEFS -[hidden]right-> SELECT_CFG

SELECT_CFG -[hidden]down-> INPUT
INPUT -[hidden]right-> BUILD_EVENTLIST
BUILD_EVENTLIST -[hidden]right-> EVENTLIST
BUILD_EVENTLIST -[hidden]down-> BUILD_SYST
EVENTLIST -[hidden]down-> SNAPSHOT
BUILD_SYST -[hidden]right-> SNAPSHOT
SNAPSHOT -[hidden]right-> PLOT_HIST

' =============================================================================
' Wiring
' =============================================================================
MK_SAMPLE --> SAMPLE : builds / writes
INPUT --> SAMPLE : partition\nsummaries
SAMPLE --> DATASET : exports sample\nmetadata
SAMPLE_DEFS ..> MK_DATASET : optional
MK_DATASET --> DATASET : writes

SELECT_CFG ..> MK_EVENTLIST : configures
MK_EVENTLIST --> BUILD_EVENTLIST : runs
MK_EVENTLIST --> BUILD_SYST : optional\ncache pass
DATASET --> BUILD_EVENTLIST : reads

BUILD_EVENTLIST --> EVENTLIST : writes
BUILD_SYST --> EVAL_SYST : drives

EVENTLIST ..> EVAL_SYST : direct row-wise path
SYSCACHE --> EVAL_SYST : loads
EVAL_SYST --> SYSCACHE : writes / refreshes
EVENTLIST --> SNAPSHOT : reads
EVENTLIST --> PLOT_HIST : reads selected trees
EVENTLIST --> PLOT_DISPLAY : reads selected trees

note left of INPUT
  InputPartitionIO scans raw ROOT file lists
  and subrun summaries before sample assembly.
end note

note left of BUILD_EVENTLIST
  ana is still the one-way translation layer:
  DatasetIO -> EventListIO
end note

note right of EVENTLIST
  Selected event trees, subrun trees,
  and copied sample metadata live here.
end note

note right of SYSCACHE
  Cached bin-wise systematics are persisted through
  EventListIO::read_systematics_cache(...) and
  EventListIO::write_systematics_cache(...).

  There is no separate DistributionIO or ChannelIO
  store in the current main branch.
end note

note bottom of PLOT_HIST
  plot/ currently reads EventListIO directly.
  It does not go through a downstream
  DistributionIO -> ChannelIO ladder.
end note

@enduml
